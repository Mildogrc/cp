{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Current C++ File",
            "type": "shell",
            "command": "/opt/homebrew/bin/g++-15 -std=gnu++23 \"${file}\" -o \"${fileDirname}/main.o\" && \"${fileDirname}/main.o\" && rm -f \"${fileDirname}/main.o\"",
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}